APP_NAME="SIDBM Export"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

# ── Database lokal sidbm-export (untuk metadata export) ──
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=sidbm_export
DB_USERNAME=root
DB_PASSWORD=

# ── Database SIDBM utama (sumber data yang akan dieksport) ──
SIDBM_DB_HOST=127.0.0.1
SIDBM_DB_PORT=3306
SIDBM_DB_DATABASE=sidbm
SIDBM_DB_USERNAME=root
SIDBM_DB_PASSWORD=

# ── EnStorage ──
ENSTORAGE_URL=https://enstorage.enpiistudio.com
ENSTORAGE_API_KEY=
